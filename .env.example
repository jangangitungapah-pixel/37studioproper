

# OneSignal Web Push
# App ID dari OneSignal Dashboard > Settings > Keys & IDs.
# Ini bukan REST API Key. Jangan taruh REST API Key di frontend.
VITE_ONESIGNAL_APP_ID=03b8a3dc-1adf-4dfd-8758-6fd0425d6d14
VITE_ONESIGNAL_SAFARI_WEB_ID=web.onesignal.auto.18c45a69-7bf7-46f8-9483-0a7df130c3b6
VITE_NOTIFICATION_WORKER_URL=https://studio37-onesignal-notification-worker.studio37.workers.dev

# Studio Owner
# Email pemilik studio — digunakan untuk bootstrap ownership admin pertama.
VITE_OWNER_EMAIL=

# Cloudinary Image Upload
# Cloud name dan preset dari Cloudinary Dashboard > Settings > Upload Presets.
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
