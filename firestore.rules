rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isBootstrapOwnerEmail() {
      return isSignedIn() &&
        request.auth.token.email != null &&
        request.auth.token.email.lower() == 'marsicprod@gmail.com';
    }

    function userHasExplicitRole() {
      return isSignedIn() && getUserDoc().keys().hasAny(['role']);
    }

    function isOwner() {
      return isSignedIn() && (
        getUserDoc().role == 'owner' ||
        (!userHasExplicitRole() && isBootstrapOwnerEmail())
      );
    }

    function isApproved() {
      return isOwner() || (
        isSignedIn() && getUserDoc().status == 'approved'
      );
    }

    function hasPermission(page) {
      return isOwner() || (
        isApproved() && (
          getUserDoc().permissions == null ||
          getUserDoc().permissions[page] == true
        )
      );
    }

    function canAccessBookingData() {
      return hasPermission('dashboard') ||
        hasPermission('schedule') ||
        hasPermission('customers') ||
        hasPermission('billing');
    }

    function canAccessCustomerData() {
      return hasPermission('dashboard') ||
        hasPermission('customers');
    }

    function canAccessBookkeepingData() {
      return hasPermission('dashboard') ||
        hasPermission('bookkeeping');
    }

    function canAccessInventoryData() {
      return hasPermission('dashboard') ||
        hasPermission('inventory');
    }

    function hasAuthEmail() {
      return isSignedIn() && request.auth.token.email != null;
    }

    function hasAuthPhone() {
      return isSignedIn() && request.auth.token.phone_number != null;
    }

    function isClientBookingOwner() {
      return isSignedIn() && (
        (
          hasAuthEmail() &&
          resource.data.email is string &&
          resource.data.email.lower() == request.auth.token.email.lower()
        ) ||
        (
          hasAuthPhone() &&
          (
            (
              resource.data.phone is string &&
              (
                resource.data.phone == request.auth.token.phone_number ||
                ('+' + resource.data.phone) == request.auth.token.phone_number
              )
            ) ||
            (
              resource.data.customerPhoneKey is string &&
              (
                resource.data.customerPhoneKey == request.auth.token.phone_number ||
                ('+' + resource.data.customerPhoneKey) == request.auth.token.phone_number
              )
            )
          )
        )
      );
    }

    function isValidString(val) {
      return val is string && val.size() > 0;
    }

    function isValidNumber(val, minVal) {
      return (val is int || val is float) && val >= minVal;
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isOwner());
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isOwner() || (
        isSignedIn() &&
        request.auth.uid == userId &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName', 'updatedAt'])
      );
      allow delete: if isOwner();
    }

    match /clientCalendarSlots/{slotId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isApproved() && canAccessBookingData();
    }

    match /bookings/{bookingId} {
      allow read: if (isApproved() && canAccessBookingData()) || isClientBookingOwner();
      allow create, update: if isApproved() &&
        canAccessBookingData() &&
        isValidString(request.resource.data.customer) &&
        isValidNumber(request.resource.data.total, 0) &&
        isValidNumber(request.resource.data.durationHours, 0);
      allow delete: if isApproved() && canAccessBookingData();
    }

    match /customers/{customerId} {
      allow read: if isApproved() && canAccessCustomerData();
      allow create, update: if isApproved() &&
        canAccessCustomerData() &&
        isValidString(request.resource.data.name) &&
        isValidString(request.resource.data.phone);
      allow delete: if isApproved() && canAccessCustomerData();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isApproved() && hasPermission('settings');
    }

    match /gallery/{imageId} {
      allow read: if true;
      allow write: if isApproved() && hasPermission('gallery');
    }

    match /bookkeepingEntries/{entryId} {
      allow read: if isApproved() && canAccessBookkeepingData();
      allow create, update: if isApproved() &&
        canAccessBookkeepingData() &&
        isValidString(request.resource.data.title) &&
        isValidNumber(request.resource.data.amount, 0) &&
        (request.resource.data.type == 'income' || request.resource.data.type == 'expense');
      allow delete: if isApproved() && canAccessBookkeepingData();
    }

    match /inventoryItems/{itemId} {
      allow read: if isApproved() && canAccessInventoryData();
      allow create, update: if isApproved() &&
        canAccessInventoryData() &&
        isValidString(request.resource.data.name) &&
        isValidNumber(request.resource.data.quantity, 0) &&
        isValidNumber(request.resource.data.minStock, 0);
      allow delete: if isApproved() && canAccessInventoryData();
    }

    match /inventoryMovements/{movementId} {
      allow read: if isApproved() && canAccessInventoryData();
      allow create: if isApproved() &&
        canAccessInventoryData() &&
        isValidString(request.resource.data.itemName) &&
        isValidNumber(request.resource.data.quantity, 0);
      allow update, delete: if false;
    }

    match /mail/{mailId} {
      allow create: if isSignedIn();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
